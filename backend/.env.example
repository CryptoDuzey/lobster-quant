# Backend example config. Copy to backend/.env before running locally.

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
LOBSTER_SECRET_KEY=change_this_to_a_long_random_string

# Optional: keep default if you want local persistent data under backend/app/data.
# LOBSTER_DB_PATH=backend/app/data/lobster_quant.db

# Optional: if rqalpha needs a separate Python runtime.
# RQALPHA_PYTHON=C:\path\to\python.exe

# Optional: install TA-Lib manually if you want native TA-Lib indicators.
# The project can run without TA-Lib and will use pandas/numpy fallbacks.
